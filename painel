)
def update_all(semanas, locais, triagens, terminais):
dff = filter_df(df, semanas, locais, triagens, terminais)
# ── KPIs ──────────────────────────────────
qtd_total = dff["Quantidade"].sum()
qtd_term = dff[dff["Terminais"] != "Acessórios"]["Quantidade"].sum()
qtd_acess = dff[dff["Terminais"] == "Acessórios"]["Quantidade"].sum()
n_labs = dff["Local"].nunique()
# ── G-SEMANA: barras agrupadas por semana ──
sem_df = (dff.groupby("semana")["Quantidade"].sum()
.reindex(SEMANA_ORDER).dropna().reset_index())
fig_sem = go.Figure(go.Bar(
x=sem_df["semana"],
y=sem_df["Quantidade"],
marker=dict(color=SEMANA_COLORS[:len(sem_df)], line=dict(width=0)),
text=[fmt_num(v) for v in sem_df["Quantidade"]],
textposition="outside",
textfont=dict(color=TEXT_WHITE, size=11),
))
fig_sem.update_layout(
**CHART_LAYOUT,
title=dict(text="Volume por Semana", font=dict(color=TEXT_WHITE, size=13)),
xaxis=dict(gridcolor=CARD_BORDER, color=TEXT_GRAY),
yaxis=dict(gridcolor=CARD_BORDER, color=TEXT_GRAY, showgrid=True),
)
# ── G-LOCAL: donut ─────────────────────────
loc_df = dff.groupby("Local")["Quantidade"].sum().reset_index()
fig_loc = go.Figure(go.Pie(
labels=loc_df["Local"],
values=loc_df["Quantidade"],
hole=0.55,
marker=dict(colors=[LOCAIS_COLORS.get(l, ACCENT_BLUE) for l in loc_df["Local"]],
line=dict(color=DARK_BG, width=2)),
textinfo="percent",
textfont=dict(color=TEXT_WHITE, size=10),
))
fig_loc.update_layout(
**CHART_LAYOUT,
title=dict(text="Volume por Local", font=dict(color=TEXT_WHITE, size=13)),
legend=dict(font=dict(size=9), orientation="v"),
)
# ── G-TERMINAL: horizontal stacked por semana ─
term_df = (dff[dff["Terminais"] != "Acessórios"]
.groupby(["semana", "Terminais"])["Quantidade"].sum()
.reset_index())
top_terms = (term_df.groupby("Terminais")["Quantidade"].sum()
.nlargest(8).index.tolist())
term_df2 = term_df[term_df["Terminais"].isin(top_terms)]
pal = px.colors.qualitative.Bold
fig_term = go.Figure()
for i, t in enumerate(top_terms):
sub = term_df2[term_df2["Terminais"] == t]
fig_term.add_trace(go.Bar(
name=t,
x=[sub[sub["semana"] == s]["Quantidade"].sum() for s in SEMANA_ORDER],
y=SEMANA_ORDER,
orientation="h",
marker=dict(color=pal[i % len(pal)]),
text=[fmt_num(sub[sub["semana"] == s]["Quantidade"].sum()) if sub[sub["semana"] == textposition="inside",
textfont=dict(size=9),
))
fig_term.update_layout(
**CHART_LAYOUT,
barmode="stack",
title=dict(text="Terminais por Semana (Top 8)", font=dict(color=TEXT_WHITE, size=13)),
