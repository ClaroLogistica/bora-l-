def fmt_num(n: float) -> str:
if n >= 1_000_000:
return f"{n/1_000_000:.2f}M"
if n >= 1_000:
return f"{n/1_000:.1f}K"
return str(int(n))
def filter_df(df, semanas=None, locais=None, triagens=None, terminais=None):
mask = pd.Series(True, index=df.index)
if semanas:
mask &= df["semana"].isin(semanas)
if locais:
mask &= df["Local"].isin(locais)
if triagens:
mask &= df["Triagem"].isin(triagens)
if terminais:
t_filter = df["Terminais"].isin(terminais)
mask &= t_filter
return df[mask]
