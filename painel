def load_data(filepath: str) -> pd.DataFrame:
df = pd.read_excel(filepath)
# Normaliza nomes de colunas
df.columns = df.columns.str.strip()
# Converte data numérica Excel → datetime
if df["Data"].dtype in ["int64", "float64"]:
df["Data"] = pd.to_datetime(df["Data"], origin="1899-12-30", unit="D")
else:
df["Data"] = pd.to_datetime(df["Data"], errors="coerce")
return df
# Tenta carregar o arquivo passado como argumento ou usa o padrão
DEFAULT_FILE = "Triagem_Março.xlsx"
filepath = sys.argv[1] if len(sys.argv) > 1 else DEFAULT_FILE
try:
df = load_data(filepath)
except FileNotFoundError:
print(f" Arquivo '{filepath}' não encontrado.")
print(" Informe o caminho: python dashboard_claro.py <arquivo.xlsx>")
sys.exit(1)
