yaxis=dict(gridcolor=CARD_BORDER, color=TEXT_GRAY, categoryorder="array", categoryarray=legend=dict(font=dict(size=9), orientation="h", y=-0.2),
)
# ── G-GIRO: rosca ─────────────────────────
if "Giro" in dff.columns:
